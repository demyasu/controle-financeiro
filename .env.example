# Database (PostgreSQL)
DATABASE_URL=postgres://user:password@localhost:5432/controle_financeiro

# SMTP (obrigatório para enviar emails de cadastro, recuperação e 2FA)
# Opção 1: SendGrid (recomendado para Render - gratuito)
SENDGRID_API_KEY= seu_api_key_sendgrid

# Opção 2: SMTP genérico (Office365, Gmail, etc)
SMTP_SERVER=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=seu@email.com
SMTP_PASSWORD=sua_senha
SMTP_FROM=seu@email.com
SMTP_FROM_NAME=Controle Financeiro

# Session secret (gere com: openssl rand -hex 32)
SESSION_SECRET=change_me_to_a_random_secret
