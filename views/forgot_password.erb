<div class="row justify-content-center" style="margin-top: 60px;">
  <div class="col-md-5">
    <div class="card shadow-lg" style="border-radius: 20px; overflow: hidden;">
      <div class="card-header text-center" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 40px 20px; border: none;">
        <div style="font-size: 3rem; margin-bottom: 10px;">🔒</div>
        <h3 class="mb-1" style="color: white; font-weight: bold;">Recuperar Senha</h3>
        <p style="color: rgba(255,255,255,0.8); margin: 0;">Digite seu email para receber o link de redefinição</p>
      </div>
      <div class="card-body" style="padding: 40px;">
        <% if @error %>
          <div class="alert alert-danger"><%= @error %></div>
        <% end %>
        <% if @notice %>
          <div class="alert alert-success"><%= @notice %></div>
        <% end %>
        <form action="/forgot_password" method="post">
          <div class="mb-4">
            <label class="form-label fw-bold">📧 Email</label>
            <input type="email" class="form-control form-control-lg" name="email" placeholder="seu@email.com" required autofocus>
          </div>
          <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">Enviar link de redefinição</button>
          <div class="text-center mt-3">
            <a href="/login" class="text-decoration-none" style="color: #667eea;">
              ← Voltar ao login
            </a>
          </div>
        </form>
        <% if @dev_link %>
          <div class="alert alert-info mt-3">
            <strong>Modo desenvolvimento:</strong><br>
            <a href="<%= @dev_link %>"><%= @dev_link %></a>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
