<div class="row justify-content-center" style="margin-top: 60px;">
  <div class="col-md-5">
    <div class="card shadow-lg" style="border-radius: 20px; overflow: hidden;">
      <div class="card-header text-center" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 40px 20px; border: none;">
        <div style="font-size: 3rem; margin-bottom: 10px;">🍀</div>
        <h3 class="mb-1" style="color: white; font-weight: bold;">Pcyasuic</h3>
        <p style="color: rgba(255,255,255,0.8); margin: 0;">Controle Financeiro</p>
      </div>
      <div class="card-body" style="padding: 40px;">
        <form action="/authenticate" method="post">
          <div class="mb-4">
            <label class="form-label fw-bold">📧 Email</label>
            <input type="email" class="form-control form-control-lg" name="email" placeholder="seu@email.com" required autofocus>
          </div>
          <div class="mb-4">
            <label class="form-label fw-bold">🔒 Senha</label>
            <input type="password" class="form-control form-control-lg" name="password" placeholder="************" required>
          </div>
          <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">Entrar</button>
          <div class="text-center mt-3">
            <a href="/register" class="text-decoration-none" style="color: #667eea;">
              🆕 Primeiro acesso? Cadastre-se
            </a>
          </div>
          <div class="text-center mt-2">
            <a href="/forgot_password" class="text-decoration-none" style="color: #6c757d; font-size: 0.9rem;">
              🔒 Esqueci a senha?
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>