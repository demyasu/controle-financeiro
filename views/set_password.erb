<div class="row justify-content-center" style="margin-top: 60px;">
  <div class="col-md-5">
    <div class="card shadow-lg" style="border-radius: 20px; overflow: hidden;">
      <div class="card-header text-center" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 40px 20px; border: none;">
        <div style="font-size: 3rem; margin-bottom: 10px;">🔐</div>
        <h3 class="mb-1" style="color: white; font-weight: bold;">Criar Conta</h3>
        <p style="color: rgba(255,255,255,0.8); margin: 0;">Defina seu usuário e senha</p>
      </div>
      <div class="card-body" style="padding: 40px;">
        <p class="text-muted text-center mb-4">Email: <strong><%= @email %></strong></p>
        <form action="/register/<%= @token %>" method="post">
          <div class="mb-3">
            <label class="form-label fw-bold">👤 Nome de Usuário</label>
            <input type="text" class="form-control form-control-lg" name="username" placeholder="Seu nome" required autofocus>
          </div>
          <div class="mb-3">
            <label class="form-label fw-bold">🔒 Senha</label>
            <div class="input-group">
              <input type="password" class="form-control form-control-lg" name="password" id="password" placeholder="************" required minlength="6">
              <span class="input-group-text" id="passwordCheck"><i class="bi bi-x-circle-fill text-danger"></i></span>
            </div>
            <div class="form-text">Mínimo de 6 caracteres.</div>
          </div>
          <div class="mb-4">
            <label class="form-label fw-bold">🔒 Confirmar Senha</label>
            <div class="input-group">
              <input type="password" class="form-control form-control-lg" name="confirm_password" id="confirm_password" placeholder="************" required minlength="6">
              <span class="input-group-text" id="confirmCheck"><i class="bi bi-x-circle-fill text-danger"></i></span>
            </div>
            <div id="matchMessage" class="form-text"></div>
          </div>
          <button type="submit" id="submitBtn" class="btn btn-primary btn-lg w-100" disabled>Criar Conta</button>
          <script>
            const pwd = document.getElementById('password');
            const conf = document.getElementById('confirm_password');
            const pwdCheck = document.getElementById('passwordCheck');
            const confCheck = document.getElementById('confirmCheck');
            const matchMsg = document.getElementById('matchMessage');
            const submitBtn = document.getElementById('submitBtn');

            function validatePasswords() {
              const pwdOk = pwd.value.length >= 6;
              const confOk = conf.value.length >= 6;
              const match = pwd.value === conf.value && pwd.value.length > 0;

              pwdCheck.innerHTML = pwdOk
                ? '<i class="bi bi-check-circle-fill text-success"></i>'
                : '<i class="bi bi-x-circle-fill text-danger"></i>';

              confCheck.innerHTML = match
                ? '<i class="bi bi-check-circle-fill text-success"></i>'
                : '<i class="bi bi-x-circle-fill text-danger"></i>';

              if (conf.value.length > 0 && !match) {
                matchMsg.innerHTML = '<span class="text-danger">As senhas não conferem</span>';
              } else if (match) {
                matchMsg.innerHTML = '<span class="text-success"><i class="bi bi-check-circle-fill"></i> Senhas conferem</span>';
              } else {
                matchMsg.innerHTML = '';
              }

              submitBtn.disabled = !(pwdOk && match);
            }

            pwd.addEventListener('input', validatePasswords);
            conf.addEventListener('input', validatePasswords);
            validatePasswords();
          </script>
        </form>
      </div>
    </div>
  </div>
</div>