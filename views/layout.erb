<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Controle Financeiro - Pcyasuic</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
  <style>
    body { 
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      padding-top: 20px;
      padding-bottom: 40px;
    }
    .main-container { 
      max-width: 1300px; 
      margin: 0 auto;
    }
    .navbar {
      background: rgba(255,255,255,0.95) !important;
      box-shadow: 0 2px 20px rgba(0,0,0,0.1);
      padding: 15px 0;
      position: sticky;
      top: 0;
      z-index: 1030;
    }
    @media (max-width: 768px) {
      .navbar-brand {
        font-size: 1.2rem !important;
      }
      .nav-link {
        padding: 8px 10px !important;
        font-size: 0.9rem;
      }
    }
    @media (max-width: 576px) {
      .navbar-brand {
        font-size: 1rem !important;
      }
      .nav-link {
        padding: 6px 8px !important;
        font-size: 0.85rem;
      }
    }
    .navbar-brand {
      color: #667eea !important;
      font-weight: bold;
      font-size: 1.5rem;
    }
    .nav-link {
      color: #333 !important;
      font-weight: 500;
      margin: 0 10px;
      border-radius: 8px;
      padding: 8px 16px !important;
      transition: all 0.3s;
    }
    .nav-link:hover {
      background: #667eea;
      color: white !important;
    }
    .card {
      border: none;
      border-radius: 15px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
      margin-bottom: 20px;
    }
    .card-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      border-radius: 15px 15px 0 0 !important;
      padding: 20px;
      font-weight: bold;
      border: none;
    }
    .table {
      margin-bottom: 0;
    }
    .table thead th {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
      color: white !important;
      border: none;
      padding: 15px;
      font-weight: 600;
      text-transform: uppercase;
      font-size: 0.85rem;
      letter-spacing: 0.5px;
    }
    .table tbody td {
      padding: 12px 15px;
      vertical-align: middle;
    }
    .table tbody tr:hover {
      background-color: #f0f0ff !important;
      transition: background-color 0.3s;
    }
    .btn-primary {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      border: none;
      border-radius: 8px;
      padding: 10px 25px;
      font-weight: 500;
      transition: all 0.3s;
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
    }
    .btn-success {
      border-radius: 8px;
      padding: 10px 25px;
      font-weight: 500;
    }
    .btn-warning, .btn-danger {
      border-radius: 6px;
      padding: 5px 15px;
      font-size: 0.85rem;
    }
    .stat-card {
      background: white;
      border-radius: 15px;
      padding: 25px;
      box-shadow: 0 5px 20px rgba(0,0,0,0.08);
      transition: transform 0.3s;
      height: 100%;
    }
    .stat-card:hover {
      transform: translateY(-5px);
    }
    h1 {
      color: white;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
      margin-bottom: 30px;
    }
    .form-label {
      font-weight: 500;
      color: #333;
    }
    .form-control, .form-select {
      border-radius: 8px;
      border: 2px solid #e0e0e0;
      padding: 10px 15px;
      transition: border-color 0.3s;
    }
    .form-control:focus, .form-select:focus {
      border-color: #667eea;
      box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
    }
  </style>
</head>
<body>
  <% if session[:user_email] %>
  <nav class="navbar navbar-expand-lg">
    <div class="container">
      <a class="navbar-brand" href="/">🍀 Pcyasuic - Controle Financeiro <% if session[:user_email] %><% user = DB.transaction(true) { DB[:users][session[:user_email]] } %><% if user && user[:admin] %><span class="badge bg-warning text-dark ms-2" style="font-size: 0.6rem;">ADMIN</span><% end %><% end %></a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/">🏠 Início</a>
          <a class="nav-link" href="/new">➕ Nova Transação</a>
          <a class="nav-link" href="/dashboard">📈 Dashboard Dívidas</a>
          <a class="nav-link" href="/export">📊 Exportar Excel</a>
          <a class="nav-link text-danger" href="/logout">🚪 Sair</a>
        </div>
      </div>
    </div>
  </nav>
  <% end %>
  <div class="container-fluid main-container">
      <div class="container" style="margin-top: 30px;">
        <% if defined?(@notice) && @notice %><div class="alert alert-success alert-dismissible fade show" role="alert"><%= @notice %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% end %>
        <% if defined?(@error) && @error %><div class="alert alert-danger alert-dismissible fade show" role="alert"><%= @error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% end %>
        <%= yield %>
      </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</body>
</html>
