<div class="row justify-content-center" style="margin-top: 60px;">
  <div class="col-md-5">
    <div class="card shadow-lg" style="border-radius: 20px; overflow: hidden;">
      <div class="card-header text-center" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 40px 20px; border: none;">
        <div style="font-size: 3rem; margin-bottom: 10px;">🔑</div>
        <h3 class="mb-1" style="color: white; font-weight: bold;">Nova Senha</h3>
        <p style="color: rgba(255,255,255,0.8); margin: 0;">Defina sua nova senha</p>
      </div>
      <div class="card-body" style="padding: 40px;">
        <% if @error %>
          <div class="alert alert-danger"><%= @error %></div>
        <% end %>
        <form action="/reset_password/<%= @token %>" method="post">
          <input type="hidden" name="token" value="<%= @token %>">
          <div class="mb-4">
            <label class="form-label fw-bold">🔒 Nova Senha</label>
            <input type="password" class="form-control form-control-lg" name="password" placeholder="Mínimo 6 caracteres" required minlength="6">
          </div>
          <div class="mb-4">
            <label class="form-label fw-bold">🔒 Confirmar Senha</label>
            <input type="password" class="form-control form-control-lg" name="confirm_password" placeholder="Repita a senha" required minlength="6">
          </div>
          <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">Redefinir Senha</button>
          <div class="text-center mt-3">
            <a href="/login" class="text-decoration-none" style="color: #667eea;">
              ← Voltar ao login
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
