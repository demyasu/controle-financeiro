<div class="row justify-content-center" style="margin-top: 60px;">
  <div class="col-md-5">
    <div class="card shadow-lg" style="border-radius: 20px; overflow: hidden;">
      <div class="card-header text-center" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 40px 20px; border: none;">
        <div style="font-size: 3rem; margin-bottom: 10px;">📧</div>
        <h3 class="mb-1" style="color: white; font-weight: bold;">Link Enviado!</h3>
        <p style="color: rgba(255,255,255,0.8); margin: 0;">Verifique seu email</p>
      </div>
      <div class="card-body" style="padding: 40px; text-align: center;">
        <p class="mb-4">Um link de cadastro foi enviado para:</p>
        <p class="fw-bold fs-5" style="color: #667eea;"><%= @email %></p>
        <p class="text-muted">Clique no link enviado para criar seu usuário e senha.</p>
        <hr class="my-4">
        <p class="text-muted small">Não recebeu o email? <a href="/register" style="color: #667eea;">Tente novamente</a></p>

        <div class="mt-3">
          <a href="/login" class="text-decoration-none" style="color: #667eea;">← Voltar para login</a>
        </div>
      </div>
    </div>
  </div>
</div>